meta {
  name: Create Text File
  type: http
  seq: 2
}

post {
  url: {{LaravelAppUrl}}/{{StorageManagerPrefix}}/fm/create-file
  body: json
  auth: inherit
}

body:json {
  {
    "disk": "public",
    "path": "/",
    "name": "New Text file",
    "content": "Hello world"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
