meta {
  name: Rename path (Directory)
  type: http
  seq: 5
}

put {
  url: {{LaravelAppUrl}}/{{StorageManagerPrefix}}/fm/rename
  body: json
  auth: inherit
}

body:json {
  {
    "disk": "public",
    "path": "/New Directory 20-02",
    "to": "New Directory 20-02 renamed"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
