{
  "name": "kwaadpepper/laravel-storage-manager",
  "description": "A Laravel file manager that can handle multiple storages",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Kwaadpepper\\LaravelStorageManager\\": "src/app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Jérémy Munsch",
      "email": "github@jeremydev.ovh"
    }
  ],
  "require": {
    "php": "^8.4",
    "ext-zip": "*",
    "ext-json": "*",
    "laravel/framework": "^12.0|^13.0"
  },
  "require-dev": {
    "laravel/pint": "^1.29",
    "orchestra/testbench": "^10.11",
    "slevomat/coding-standard": "^8.28",
    "league/flysystem-aws-s3-v3": "^3.32",
    "league/flysystem-ftp": "^3.31",
    "league/flysystem-sftp-v3": "^3.31",
    "pestphp/pest": "^4.4",
    "pestphp/pest-plugin-laravel": "^4.1",
    "pestphp/pest-plugin-type-coverage": "^4.0",
    "phpstan/phpstan": "^2.1",
    "larastan/larastan": "^3.9",
    "ace-of-aces/intellipest": "^0.3.0",
    "pestphp/pest-plugin-arch": "^4.0"
  },
  "suggest": {
    "league/flysystem-aws-s3-v3": "Required to use S3 storage",
    "league/flysystem-ftp": "Required to use FTP storage",
    "league/flysystem-sftp-v3": "Required to use SFTP storage"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Kwaadpepper\\LaravelStorageManager\\Provider\\StorageManagerServiceProvider"
      ],
      "aliases": {}
    }
  },
  "scripts": {
    "test": "vendor/bin/pest",
    "test:coverage": "vendor/bin/pest --coverage --coverage-html=coverage",
    "test:type-coverage": "vendor/bin/pest --type-coverage",
    "analyse": "vendor/bin/phpstan analyse",
    "format": "vendor/bin/pint"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "pestphp/pest-plugin": true
    }
  }
}
